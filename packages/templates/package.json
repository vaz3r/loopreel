{
  "name": "@loopreel/templates",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/editorial-runway dist/protocol-001 dist/archive && cp src/editorial-runway/prompt.txt dist/editorial-runway/prompt.txt && cp src/protocol-001/prompt.txt dist/protocol-001/prompt.txt && cp src/archive/prompt.txt dist/archive/prompt.txt",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@loopreel/design": "workspace:*",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
