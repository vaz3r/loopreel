# Infrastructure
DATABASE_URL="postgresql://loopreel:loopreel@localhost:5432/loopreel"
REDIS_URL="redis://localhost:6379"

# External APIs
LLM_API_KEY=""
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="openrouter/free"
LLM_TIMEOUT=60000
LLM_MAX_RETRIES=3

# Unsplash API
UNSPLASH_ACCESS_KEY=""
UNSPLASH_SECRET_KEY=""

# Cloudflare R2 Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="loopreel"

# App
API_PORT=3000
LOG_LEVEL="info"

# Whisper (for worker-transcribe)
WHISPER_URL="http://localhost:8000"

# Render URL (for worker-render)
RENDER_URL="http://localhost:5173"

# Browser pool (for worker-render)
PLAYWRIGHT_POOL_SIZE=5
METRICS_PORT=8004
