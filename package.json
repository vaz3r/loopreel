{
  "name": "loopreel",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter @loopreel/db run migrate",
    "db:generate": "pnpm --filter @loopreel/db run generate"
  }
}
